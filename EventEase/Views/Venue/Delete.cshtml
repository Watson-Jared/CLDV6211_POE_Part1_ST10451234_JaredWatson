@model EventEase.Models.Venue
@{
    ViewData["Title"] = "Delete Venue";
}

<h1>Delete Venue</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <div class="delete-warning">
            <div class="delete-warning-title">⚠ This action cannot be undone.</div>
            <dl class="row">
                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.VenueName)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.VenueName)</dd>
                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Location)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Location)</dd>
                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Capacity)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Capacity)</dd>
            </dl>
        </div>
        <form asp-action="Delete" class="d-flex gap-2">
            <input type="hidden" asp-for="VenueID" />
            <input type="submit" value="Yes, Delete" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>