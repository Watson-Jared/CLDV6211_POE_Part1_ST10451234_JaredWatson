@model EventEase.Models.Venue
@{
    ViewData["Title"] = "Venue Details";
}

<h1>Venue Details</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <div class="form-card">
            <dl class="row">
                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.VenueID)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.VenueID)</dd>
                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.VenueName)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.VenueName)</dd>
                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Location)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Location)</dd>
                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Capacity)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Capacity)</dd>
                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.ImageUrl)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.ImageUrl)</dd>
            </dl>
        </div>
        <div class="mt-3 d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model?.VenueID" class="btn btn-primary">Edit</a>
            <a asp-action="Index" class="btn btn-secondary">← Back</a>
        </div>
    </div>
</div>