@model IEnumerable<EventEase.Models.Booking>
@{
    ViewData["Title"] = "Bookings";
}

<h1>Bookings</h1>
<p><a asp-action="Create">+ New Booking</a></p>

<div class="table-wrapper">
    <table class="table">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.BookingID)</th>
                <th>Event</th>
                <th>Venue</th>
                <th>@Html.DisplayNameFor(model => model.BookingStartDate)</th>
                <th>@Html.DisplayNameFor(model => model.BookingEndDate)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="color:#4d6490; font-family:'JetBrains Mono',monospace; font-size:0.8rem;">#@Html.DisplayFor(modelItem => item.BookingID)</td>
                    <td>@Html.DisplayFor(modelItem => item.Event.EventName)</td>
                    <td>@Html.DisplayFor(modelItem => item.Venue.Location)</td>
                    <td>@Html.DisplayFor(modelItem => item.BookingStartDate)</td>
                    <td>@Html.DisplayFor(modelItem => item.BookingEndDate)</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.BookingID" class="action-edit">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.BookingID" class="action-details">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.BookingID" class="action-delete">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>